# ServiceSync Pilot Intelligence Dashboard — environment
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- AWS (read access to the pilot data buckets + Transcribe) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Data sources ---
AUDIO_BUCKET=servicesync-dealership-audio
EVENTS_BUCKET=servicesync-advisor-data
# Advisor / dealership prefixes within the buckets
AUDIO_PREFIX=siltaylor/
TRANSCRIPTS_PREFIX=transcripts/
EVENTS_PREFIX=raw-events/chevyland_chevrolet/
ADVISOR_ID=siltaylor

# --- Live PC access (Tailscale) ---
DEALER_PC_IP=100.104.185.115
SSH_USER=sil
SSH_KEY_PATH=~/.ssh/id_ed25519_servicesync_deploy

# --- Auth (simple password gate; this is a founder-only internal tool) ---
DASHBOARD_PASSWORD=change-me
